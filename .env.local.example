NEXT_PUBLIC_CHAIN_ID=11155111
# Boleh beberapa RPC dipisah koma — app failover otomatis
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com,https://sepolia.drpc.org
# MockUSDT (ERC-20 6 desimal) di Sepolia — mint() terbuka untuk saldo uji
NEXT_PUBLIC_USDT_ADDRESS=0x0304dda2A4F3B6Daa28ad87CacEeea4B634F5a28
NEXT_PUBLIC_EXPLORER=https://sepolia.etherscan.io
# TarkamEscrow — kontrak brankas trustless di Sepolia (mode escrow)
NEXT_PUBLIC_ESCROW_ADDRESS=0xd572cffB8d01f1FFD129A88F301209dA346E2d5f

# ── Gasless (opsional) ────────────────────────────────────────────────────
# Bila diisi, jalur KAPTEN (deposit/approve payout/refund) di /join beralih
# ke gasless via WDK `wdk-wallet-evm-7702-gasless` (EIP-7702 + ERC-4337) —
# kapten tidak perlu punya ETH sama sekali, gas disponsori paymaster.
# Tanpa env ini, app 100% identik dengan jalur klasik (kapten tetap butuh ETH).
#
# Butuh akun Pimlico gratis (https://dashboard.pimlico.io) + API key, lalu
# buat "Sponsorship Policy" di dashboard-nya (mode sponsored) untuk chain
# Sepolia (id 11155111) agar UserOperation kapten benar-benar gratis.
# NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_PIMLICO_KEY
# NEXT_PUBLIC_SPONSORSHIP_POLICY_ID=sp_your_policy_id
# Opsional — default sudah SimpleAccount 7702 resmi Pimlico di Sepolia:
# NEXT_PUBLIC_DELEGATION_ADDRESS=0xe6Cae83BdE06E4c305530e199D7217f42808555B
